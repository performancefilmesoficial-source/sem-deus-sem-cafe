# Variáveis de ambiente necessárias para o deploy
# Copie este arquivo para .env.local e preencha com seus valores do Supabase
# Em produção (Vercel/Netlify), configure estas variáveis no painel do serviço

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
